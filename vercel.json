{
  "version": 2,
  "buildCommand": "bash vercel-build.sh",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "nodeVersion": "22.x",
  "regions": ["sfo1"],
  "env": {
    "NODE_ENV": "production"
  },
  "turbo": {
    "tasks": {
      "build": {
        "cache": false,
        "dependsOn": []
      }
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
# This file shows all required environment variables for the eSign Platform
# Copy this to .env.local and fill in your actual values
# NEVER commit .env.local to git - it contains secret keys

# Environment
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# Database
# Supabase transaction-mode pooler for runtime API queries.
DATABASE_URL="postgresql://postgres.gcmbwwdxyhoavckpdnyd:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase session-mode pooler for Prisma migrations.
DIRECT_URL="postgresql://postgres.gcmbwwdxyhoavckpdnyd:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"
DB_POOL_MAX=5

# Redis
REDIS_URL="redis://localhost:6379"

# JWT / Authentication
JWT_SECRET=your-secret-key-minimum-64-characters-change-in-production
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# NextAuth / Google OAuth
NEXTAUTH_SECRET=your-nextauth-secret-minimum-64-characters-change-in-production
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id-from-google-cloud
GOOGLE_CLIENT_SECRET=your-google-client-secret-from-google-cloud

# AWS S3 (for file storage in production)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_KMS_KEY_ID=your-kms-key-id

# Encryption
AES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
AES_IV_LENGTH=16
DOWNLOAD_URL_SECRET=your-download-url-signing-secret-minimum-64-characters

# X402 Payment Configuration
X402_NETWORK=base-sepolia
X402_FACILITATOR_URL=https://facilitator.yourdomain.com
X402_WALLET_ADDRESS=0xa2B39121fb512817d0556Fe795574D314C355f17
X402_CHAIN_ID=84532
X402_PRICE_PER_SIGN=0.0001
X402_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_X402_WALLET=0xa2B39121fb512817d0556Fe795574D314C355f17
NEXT_PUBLIC_X402_PRICE_PER_SIGN=0.0001

# Stellar Payment Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_WALLET_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_PRICE_PER_SIGN=1.36
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_WALLET_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STELLAR_PRICE_PER_SIGN=1.36

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# TOTP/MFA Configuration
TOTP_APP_NAME=eSign
TOTP_ISSUER=eSign

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Webhook Security
WEBHOOK_SECRET=your-webhook-secret-key
